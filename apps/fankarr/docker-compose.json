{
  "schemaVersion": 2,
  "services": [
    {
      "name": "fankarr",
      "image": "masutayunikon/fankarr:1.11.9",
      "environment": [
        {
          "key": "PUID",
          "value": "1000"
        },
        {
          "key": "PGID",
          "value": "1000"
        },
        {
          "key": "TZ",
          "value": "${TZ}"
        },
        {
          "key": "GITHUB_RAW_URL",
          "value": "${GITHUB_RAW_URL}"
        }
      ],
      "internalPort": 9898,
      "volumes": [
        {
          "hostPath": "/etc/localtime",
          "containerPath": "/etc/localtime",
          "readOnly": true,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/config",
          "containerPath": "/config",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${ROOT_FOLDER_HOST}/media",
          "containerPath": "/media",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ],
      "isMain": true,
      "extraLabels": {
        "runtipi.managed": true
      }
    }
  ]
}
