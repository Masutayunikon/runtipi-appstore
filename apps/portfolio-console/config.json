{
  "$schema": "../app-info-schema.json",
  "name": "Portfolio",
  "available": true,
  "exposable": true,
  "dynamic_config": true,
  "port": 3000,
  "id": "portfolio-console",
  "tipi_version": 1,
  "version": "1.0.0",
  "categories": ["utilities", "development"],
  "description": "VS Code-themed portfolio built with Vue 3 + Vite + Express. Displays projects via GitHub API, a Spotify Now Playing widget, a blog, and a contact form.",
  "short_desc": "VS Code-themed developer portfolio",
  "author": "MasutaYunikon",
  "source": "https://github.com/Masutayunikon/Portfolio-console",
  "form_fields": [
    {
      "type": "text",
      "label": "GitHub Username",
      "hint": "Your GitHub username (used to fetch repos)",
      "required": true,
      "env_variable": "VITE_GITHUB_USERNAME",
      "default": "Masutayunikon"
    },
    {
      "type": "password",
      "label": "GitHub Token (optional)",
      "hint": "Personal access token — raises API rate limit from 60 to 5000 req/h",
      "required": false,
      "env_variable": "VITE_GITHUB_TOKEN"
    },
    {
      "type": "text",
      "label": "Spotify Client ID (optional)",
      "hint": "Leave empty to disable the Now Playing widget",
      "required": false,
      "env_variable": "VITE_SPOTIFY_CLIENT_ID"
    },
    {
      "type": "text",
      "label": "Spotify Client Secret (optional)",
      "required": false,
      "env_variable": "VITE_SPOTIFY_CLIENT_SECRET"
    },
    {
      "type": "text",
      "label": "Spotify Refresh Token (optional)",
      "required": false,
      "env_variable": "VITE_SPOTIFY_REFRESH_TOKEN"
    },
    {
      "type": "text",
      "label": "SMTP Host",
      "hint": "e.g. smtp.gmail.com",
      "required": true,
      "env_variable": "SMTP_HOST"
    },
    {
      "type": "number",
      "label": "SMTP Port",
      "required": true,
      "env_variable": "SMTP_PORT",
      "default": 587
    },
    {
      "type": "text",
      "label": "SMTP Username",
      "required": true,
      "env_variable": "SMTP_USER"
    },
    {
      "type": "password",
      "label": "SMTP Password",
      "hint": "Use an app password if 2FA is enabled",
      "required": true,
      "env_variable": "SMTP_PASS"
    },
    {
      "type": "text",
      "label": "Recipient email (contact inbox)",
      "hint": "Where contact form messages are delivered",
      "required": true,
      "env_variable": "SMTP_TO"
    }
  ],
  "supported_architectures": ["arm64", "amd64"],
  "created_at": 1773935823431,
  "updated_at": 1773935823431
}
