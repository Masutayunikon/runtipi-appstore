{
  "schemaVersion": 2,
  "services": [
    {
      "name": "pygege-dev",
      "image": "masutayunikon/pygege:1.4.1",
      "internalPort": 8000,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/app/data",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ],
      "environment": [
        {
          "key": "TMDB_API_KEY",
          "value": "${TMDB_API_KEY}"
        }
      ],
      "isMain": true,
      "extraLabels": {
        "runtipi.managed": true
      }
    }
  ]
}
