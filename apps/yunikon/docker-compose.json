{
  "schemaVersion": 2,
  "services": [
    {
      "name": "yunikon",
      "image": "ghcr.io/masutayunikon/yunikon:latest",
      "environment": [
        {
          "key": "NUXT_SMTP_HOST",
          "value": "${NUXT_SMTP_HOST}"
        },
        {
          "key": "NUXT_SMTP_PORT",
          "value": "${NUXT_SMTP_PORT}"
        },
        {
          "key": "NUXT_SMTP_USER",
          "value": "${NUXT_SMTP_USER}"
        },
        {
          "key": "NUXT_SMTP_PASS",
          "value": "${NUXT_SMTP_PASS}"
        },
        {
          "key": "NUXT_SMTP_TO",
          "value": "${NUXT_SMTP_TO}"
        }
      ],
      "internalPort": 3000,
      "isMain": true,
      "labels": {
        "traefik.enable": "true",

        "traefik.http.routers.yunikon.rule": "Host(`yunikon.re`)",
        "traefik.http.routers.yunikon.entrypoints": "websecure",
        "traefik.http.routers.yunikon.tls": "true",

        "traefik.http.routers.yunikon-www.rule": "Host(`www.yunikon.re`)",
        "traefik.http.routers.yunikon-www.entrypoints": "websecure",
        "traefik.http.routers.yunikon-www.middlewares": "redirect-www-to-root",

        "traefik.http.middlewares.redirect-www-to-root.redirectregex.regex": "^https://www\\.yunikon\\.re/(.*)",
        "traefik.http.middlewares.redirect-www-to-root.redirectregex.replacement": "https://yunikon.re/$${1}",
        "traefik.http.middlewares.redirect-www-to-root.redirectregex.permanent": "true"
      },
      "extraLabels": {
        "runtipi.managed": true
      }
    }
  ]
}